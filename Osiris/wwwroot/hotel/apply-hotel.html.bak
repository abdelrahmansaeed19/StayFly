<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Become a Partner - Hotel Partner Program</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .tabs-header {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
            border-bottom: 1px solid var(--glass-border);
            padding-bottom: 10px;
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-size: 1rem;
            font-weight: 600;
            padding: 10px 20px;
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
        }

        .tab-btn.active {
            color: var(--primary);
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -11px;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--primary);
            border-radius: 10px;
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .tab-content.active {
            display: block;
        }

        .dynamic-group {
            background: rgba(15, 23, 42, 0.3);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 24px;
        }

        .dynamic-row {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
            align-items: flex-start;
        }

        .btn-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .btn-add {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .btn-remove {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .btn-add:hover {
            background: #10b981;
            color: white;
        }

        .btn-remove:hover {
            background: #ef4444;
            color: white;
        }

        .status-card {
            padding: 30px;
            text-align: center;
        }

        .status-badge {
            display: inline-block;
            padding: 8px 24px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 1.1rem;
            margin: 20px 0;
            text-transform: uppercase;
        }

        .pending {
            background: rgba(251, 191, 36, 0.2);
            color: #fbbf24;
            border: 1px solid #fbbf24;
        }

        .approved {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
            border: 1px solid #10b981;
        }

        .edit-notice {
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-weight: 600;
            display: none;
        }
    </style>
</head>

<body>
    <div class="app-container">
        <header class="app-header">
            <a href="index.html" class="nav-icon"><i class="fas fa-arrow-left"></i></a>
            <div class="header-title">Partner Hub</div>
            <div></div>
        </header>

        <div class="container" style="max-width: 800px; padding: 40px 20px;">
            <div class="tabs-header">
                <button id="applyTabBtn" class="tab-btn active" onclick="switchTab('applyForm')">Partner
                    Application</button>
                <button id="statusTabBtn" class="tab-btn" onclick="switchTab('statusView')">Application Status</button>
            </div>

            <!-- Tab 1: Application Form -->
            <div id="applyForm" class="tab-content active">
                <div class="glass-panel" style="padding: 40px;">
                    <div id="editNotice" class="edit-notice">
                        <i class="fas fa-edit"></i> You already have an application. You can edit it now.
                    </div>

                    <div style="margin-bottom: 40px;">
                        <h1 id="formTitle" style="font-size: 2rem; margin-bottom: 10px;">Partner Registration</h1>
                        <p style="color: var(--text-muted);">Please provide your business details for verification</p>
                    </div>

                    <form id="hotelForm" onsubmit="submitApplication(event)">
                        <!-- Basic Info -->
                        <h3 style="margin-bottom: 20px; color: var(--primary);"><i class="fas fa-info-circle"></i>
                            Business Information</h3>

                        <label class="input-label">Hotel/Company Name</label>
                        <div class="input-group">
                            <i class="fas fa-hotel"></i>
                            <input type="text" id="hotelName" class="input-field" placeholder="Grand Royal Group"
                                required>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                            <div>
                                <label class="input-label">License Number</label>
                                <div class="input-group">
                                    <i class="fas fa-id-card"></i>
                                    <input type="text" id="licenseNumber" class="input-field" placeholder="L-55092"
                                        required>
                                </div>
                            </div>
                            <div>
                                <label class="input-label">Tax Identification ID</label>
                                <div class="input-group">
                                    <i class="fas fa-file-invoice-dollar"></i>
                                    <input type="text" id="taxId" class="input-field" placeholder="TX-8822" required>
                                </div>
                            </div>
                        </div>

                        <label class="input-label">Registration Document URL</label>
                        <div class="input-group">
                            <i class="fas fa-paperclip"></i>
                            <input type="url" id="registrationDoc" class="input-field" placeholder="https://..."
                                required>
                        </div>

                        <label class="input-label">Description</label>
                        <div class="input-group">
                            <textarea id="description" class="input-field" rows="3"
                                placeholder="Tell us about your brand..." style="padding-left: 16px;"></textarea>
                        </div>

                        <!-- Contact Info (Dynamic) -->
                        <h3 style="margin: 40px 0 20px 0; color: var(--primary);"><i class="fas fa-address-book"></i>
                            Contact Channels</h3>

                        <label class="input-label">Business Emails</label>
                        <div id="emailContainer" class="dynamic-group">
                            <div class="dynamic-row">
                                <input type="email" class="input-field email-input" placeholder="contact@hotel.com"
                                    style="padding-left: 16px;" required>
                                <button type="button" class="btn-icon btn-add"
                                    onclick="addDynamicField('emailContainer', 'email-input', 'email')"><i
                                        class="fas fa-plus"></i></button>
                            </div>
                        </div>

                        <label class="input-label">Phone Numbers</label>
                        <div id="phoneContainer" class="dynamic-group">
                            <div class="dynamic-row">
                                <input type="tel" class="input-field phone-input" placeholder="+20 10..."
                                    style="padding-left: 16px;" required>
                                <button type="button" class="btn-icon btn-add"
                                    onclick="addDynamicField('phoneContainer', 'phone-input', 'tel')"><i
                                        class="fas fa-plus"></i></button>
                            </div>
                        </div>

                        <!-- Addresses (Dynamic) -->
                        <h3 style="margin: 40px 0 20px 0; color: var(--primary);"><i class="fas fa-map-marker-alt"></i>
                            Headquarters & Offices</h3>
                        <div id="addressContainer" class="dynamic-group">
                            <div class="address-item"
                                style="border-bottom: 1px solid var(--glass-border); padding-bottom: 20px; margin-bottom: 20px;">
                                <div class="dynamic-row">
                                    <input type="text" class="input-field addr-val" placeholder="Full Address"
                                        style="padding-left: 16px;" required>
                                    <button type="button" class="btn-icon btn-add" onclick="addAddressField()"><i
                                            class="fas fa-plus"></i></button>
                                </div>
                                <div
                                    style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;">
                                    <input type="text" class="input-field addr-city" placeholder="City"
                                        style="padding-left: 16px;">
                                    <input type="text" class="input-field addr-country" placeholder="Country"
                                        style="padding-left: 16px;">
                                </div>
                            </div>
                        </div>

                        <button id="submitBtn" type="submit" class="btn-primary"
                            style="width: 100%; margin-top: 20px;">Submit Partner Application</button>
                        <div id="applyMsg" style="margin-top: 20px; text-align: center;"></div>
                    </form>
                </div>
            </div>

            <!-- Tab 2: Status View -->
            <div id="statusView" class="tab-content">
                <div class="glass-panel status-card">
                    <div id="statusLoading">
                        <i class="fas fa-circle-notch fa-spin fa-3x" style="color: var(--primary);"></i>
                        <p style="margin-top: 20px;">Retrieving application status...</p>
                    </div>

                    <div id="statusEmpty" style="display: none;">
                        <i class="fas fa-file-invoice fa-4x" style="opacity: 0.2; margin-bottom: 20px;"></i>
                        <h2>No Application Found</h2>
                        <p style="color: var(--text-muted); margin: 15px 0;">You haven't submitted a partner application
                            yet.</p>
                        <button class="btn-secondary" onclick="switchTab('applyForm')" style="margin-top: 10px;">Apply
                            Now</button>
                    </div>

                    <div id="statusExists" style="display: none;">
                        <div id="statusIcon"></div>
                        <h2 id="viewHotelName">--</h2>
                        <div id="viewStatusBadge" class="status-badge">--</div>

                        <div
                            style="margin-top: 30px; text-align: left; background: rgba(0,0,0,0.2); border-radius: 16px; padding: 20px;">
                            <div style="display: grid; gap: 12px;">
                                <div>
                                    <small style="color: var(--text-muted);">Submission ID</small>
                                    <p id="viewId">#--</p>
                                </div>
                                <div>
                                    <small style="color: var(--text-muted);">Submitted On</small>
                                    <p id="viewDate">--</p>
                                </div>
                                <div>
                                    <small style="color: var(--text-muted);">Verification Status</small>
                                    <p id="viewDetailMsg">--</p>
                                </div>
                            </div>
                        </div>

                        <div id="editBtnContainer" style="margin-top: 20px; display: flex; gap: 10px;">
                            <button class="btn-secondary" onclick="switchTab('applyForm')" style="flex: 1;">
                                <i class="fas fa-edit"></i> Edit Application Details
                            </button>
                            <button class="btn-primary" onclick="deleteApplication()"
                                style="flex: 1; background: var(--error);">
                                <i class="fas fa-trash-alt"></i> Delete Application
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="js/config.js"></script>
    <script>
        if (!Auth.isLoggedIn()) {
            window.location.href = 'login.html';
        }

        let existingApplication = null;

        // --- Tab Management ---
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));

            document.getElementById(tabId).classList.add('active');

            if (tabId === 'applyForm') document.getElementById('applyTabBtn').classList.add('active');
            else if (tabId === 'statusView') document.getElementById('statusTabBtn').classList.add('active');

            if (tabId === 'statusView') {
                loadStatus();
            }
        }

        // --- Dynamic Fields ---
        function addDynamicField(containerId, inputClass, type, value = '') {
            const container = document.getElementById(containerId);
            const row = document.createElement('div');
            row.className = 'dynamic-row';
            row.innerHTML = `
                <input type="${type}" class="input-field ${inputClass}" placeholder="Value" value="${value}" style="padding-left: 16px;">
                <button type="button" class="btn-icon btn-remove" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
            `;
            container.appendChild(row);
        }

        function addAddressField(data = null) {
            const container = document.getElementById('addressContainer');
            const div = document.createElement('div');
            div.className = 'address-item';
            div.style.borderBottom = '1px solid var(--glass-border)';
            div.style.paddingBottom = '20px';
            div.style.marginBottom = '20px';
            div.innerHTML = `
                <div class="dynamic-row">
                    <input type="text" class="input-field addr-val" placeholder="Full Address" value="${data ? data.address || data.Address : ''}" style="padding-left: 16px;">
                    <button type="button" class="btn-icon btn-remove" onclick="this.parentElement.parentElement.remove()"><i class="fas fa-times"></i></button>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;">
                    <input type="text" class="input-field addr-city" placeholder="City" value="${data ? data.city || data.City : ''}" style="padding-left: 16px;">
                    <input type="text" class="input-field addr-country" placeholder="Country" value="${data ? data.country || data.Country : ''}" style="padding-left: 16px;">
                </div>
            `;
            container.appendChild(div);
        }

        // --- API Actions ---
        // --- API Actions ---
        async function submitApplication(e) {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            const msg = document.getElementById('applyMsg');
            const form = document.getElementById('hotelForm');

            try {
                // Robust State Check: Use dataset mode set by populateForm/resetForm
                const mode = form.dataset.mode || 'create';
                const appId = form.dataset.id;
                const isUpdate = mode === 'update' && appId;

                console.log('Submitting Application:', { mode, appId, isUpdate });

                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Processing...';
                msg.innerHTML = '';

                const emails = Array.from(document.querySelectorAll('.email-input')).map(i => i.value).filter(v => v);
                const phones = Array.from(document.querySelectorAll('.phone-input')).map(i => i.value).filter(v => v);

                const addresses = Array.from(document.querySelectorAll('.address-item')).map(item => ({
                    address: item.querySelector('.addr-val').value,
                    city: item.querySelector('.addr-city').value,
                    country: item.querySelector('.addr-country').value
                })).filter(a => a.address);

                const payload = {
                    hotelName: document.getElementById('hotelName').value,
                    licenseNumber: document.getElementById('licenseNumber').value,
                    taxId: document.getElementById('taxId').value,
                    registrationDoc: document.getElementById('registrationDoc').value,
                    description: document.getElementById('description').value,
                    emails: emails,
                    phoneNumbers: phones,
                    addresses: addresses,
                    bankDetails: []
                };

                let res;
                if (isUpdate) {
                    res = await API.put('/Hotels/my-application', payload);
                } else {
                    res = await API.post('/Hotels/apply', payload);
                }

                if (res.success) {
                    msg.style.color = 'var(--success)';
                    msg.innerHTML = `<i class="fas fa-check-circle"></i> ${isUpdate ? 'Application updated successfully!' : 'Application submitted successfully!'}`;

                    // Hide button or update its state
                    btn.innerHTML = '<i class="fas fa-check"></i> Success';

                    setTimeout(() => {
                        loadStatus();
                        switchTab('statusView');
                    }, 1500);
                } else {
                    btn.disabled = false;
                    btn.textContent = isUpdate ? 'Update Application' : 'Submit Partner Application';
                    msg.style.color = 'var(--error)';
                    msg.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + (res.message || 'Error occurred');
                    console.error('Submission Failed:', res);
                }
            } catch (err) {
                console.error('Frontend Error:', err);
                btn.disabled = false;
                btn.textContent = 'Submit Partner Application';
                msg.style.color = 'var(--error)';
                msg.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Client Error: ' + err.message;
            }
        }

        async function deleteApplication() {
            if (!confirm('Are you sure you want to withdraw and delete your application? This action cannot be undone.')) return;

            const res = await API.delete('/Hotels/my-application');
            if (res.success) {
                alert('Application deleted successfully.');
                existingApplication = null; // Clear global state
                resetForm(); // Reset form UI and mode to 'create'

                // Force loadStatus to refresh global state, but handle the UI reset carefully
                await loadStatus();

                // Explicitly ensure we are in create mode after delete
                resetForm();

                switchTab('applyForm'); // Switch back to form tab
            } else {
                alert('Error: ' + res.message);
            }
        }

        async function loadStatus() {
            const loading = document.getElementById('statusLoading');
            const empty = document.getElementById('statusEmpty');
            const exists = document.getElementById('statusExists');

            loading.style.display = 'block';
            empty.style.display = 'none';
            exists.style.display = 'none';

            const res = await API.get('/Hotels/my-application');
            loading.style.display = 'none';

            if (res.success && res.data && (res.data.id || res.data.Id)) {
                existingApplication = res.data;
                const app = res.data;

                // Fix Pascal/Camel case issues
                const hotelName = app.hotelName || app.HotelName || 'Untitled Hotel';
                const appId = app.id || app.Id || 'N/A';
                const createdAt = app.createdAt || app.CreatedAt;
                const verified = app.verified !== undefined ? app.verified : app.Verified;

                exists.style.display = 'block';
                document.getElementById('viewHotelName').innerText = hotelName;
                document.getElementById('viewId').innerText = '#' + appId;

                if (createdAt) {
                    document.getElementById('viewDate').innerText = new Date(createdAt).toLocaleDateString();
                } else {
                    document.getElementById('viewDate').innerText = 'N/A';
                }

                const badge = document.getElementById('viewStatusBadge');
                const iconDiv = document.getElementById('statusIcon');
                const detailMsg = document.getElementById('viewDetailMsg');

                if (verified) {
                    badge.innerText = 'Approved';
                    badge.className = 'status-badge approved';
                    iconDiv.innerHTML = '<i class="fas fa-check-circle fa-4x" style="color: var(--success); margin-bottom: 20px;"></i>';
                    detailMsg.innerText = 'Congratulations! Your account is now a Partner account. You can now access the Hotel Dashboard.';
                    document.getElementById('editBtnContainer').style.display = 'none';
                } else {
                    badge.innerText = 'Pending Review';
                    badge.className = 'status-badge pending';
                    iconDiv.innerHTML = '<i class="fas fa-history fa-4x" style="color: var(--gold); margin-bottom: 20px;"></i>';
                    detailMsg.innerText = 'Your request is currently under review by our team. We will verify your data soon.';
                    document.getElementById('editBtnContainer').style.display = 'flex'; // Use flex for the buttons gap
                }

                populateForm(app);

            } else {
                existingApplication = null;
                empty.style.display = 'block';
                exists.style.display = 'none';
                resetForm();
            }
        }

        function populateForm(app) {
            document.getElementById('hotelName').value = app.hotelName || app.HotelName || '';
            document.getElementById('licenseNumber').value = app.licenseNumber || app.LicenseNumber || '';
            document.getElementById('taxId').value = app.taxId || app.TaxId || '';
            document.getElementById('registrationDoc').value = app.registrationDoc || app.RegistrationDoc || '';
            document.getElementById('description').value = app.description || app.Description || '';

            // Notice
            document.getElementById('editNotice').style.display = 'block';
            document.getElementById('formTitle').innerText = 'Edit Partner Application';
            document.getElementById('submitBtn').innerText = 'Update Application';

            // Set Form Mode to UPDATE
            const form = document.getElementById('hotelForm');
            form.dataset.mode = 'update';
            form.dataset.id = app.id || app.Id || '';

            // Collections
            const emails = app.emails || app.Emails || [];
            const emailContainer = document.getElementById('emailContainer');
            emailContainer.innerHTML = '';
            if (emails.length > 0) {
                emails.forEach(e => addDynamicField('emailContainer', 'email-input', 'email', e));
            } else {
                addDynamicField('emailContainer', 'email-input', 'email');
            }

            const phones = app.phoneNumbers || app.PhoneNumbers || [];
            const phoneContainer = document.getElementById('phoneContainer');
            phoneContainer.innerHTML = '';
            if (phones.length > 0) {
                phones.forEach(p => addDynamicField('phoneContainer', 'phone-input', 'tel', p));
            } else {
                addDynamicField('phoneContainer', 'phone-input', 'tel');
            }

            const addresses = app.addresses || app.Addresses || [];
            const addressContainer = document.getElementById('addressContainer');
            addressContainer.innerHTML = '';
            if (addresses.length > 0) {
                addresses.forEach(a => addAddressField(a));
            } else {
                addAddressField();
            }
        }

        function resetForm() {
            const form = document.getElementById('hotelForm');
            form.reset();

            // Set Form Mode to CREATE
            form.dataset.mode = 'create';
            delete form.dataset.id;

            document.getElementById('editNotice').style.display = 'none';
            document.getElementById('formTitle').innerText = 'Partner Registration';
            document.getElementById('submitBtn').innerText = 'Submit Partner Application';

            document.getElementById('emailContainer').innerHTML = '<div class="dynamic-row"><input type="email" class="input-field email-input" placeholder="contact@hotel.com" style="padding-left: 16px;" required><button type="button" class="btn-icon btn-add" onclick="addDynamicField(\'emailContainer\', \'email-input\', \'email\')"><i class="fas fa-plus"></i></button></div>';
            document.getElementById('phoneContainer').innerHTML = '<div class="dynamic-row"><input type="tel" class="input-field phone-input" placeholder="+20 10..." style="padding-left: 16px;" required><button type="button" class="btn-icon btn-add" onclick="addDynamicField(\'phoneContainer\', \'phone-input\', \'tel\')"><i class="fas fa-plus"></i></button></div>';
            document.getElementById('addressContainer').innerHTML = '<div class="address-item" style="border-bottom: 1px solid var(--glass-border); padding-bottom: 20px; margin-bottom: 20px;"><div class="dynamic-row"><input type="text" class="input-field addr-val" placeholder="Full Address" style="padding-left: 16px;" required><button type="button" class="btn-icon btn-add" onclick="addAddressField()"><i class="fas fa-plus"></i></button></div><div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;"><input type="text" class="input-field addr-city" placeholder="City" style="padding-left: 16px;"><input type="text" class="input-field addr-country" placeholder="Country" style="padding-left: 16px;"></div></div>';
        }

        // Initial load
        loadStatus();

        // Handle URL params
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('status') === 'view') {
            switchTab('statusView');
        }
    </script>
</body>

</html>